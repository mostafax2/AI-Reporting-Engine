{
    "name": "mostafax/ai-reporting-engine",
    "description": "AI Reporting Engine — turn natural-language prompts into report queries via a unified Regex + OpenAI pipeline, with prompt normalization, fingerprint caching, and a pluggable DSL builder.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "openai",
        "reporting",
        "nlp",
        "natural-language",
        "regex",
        "dsl",
        "mongodb",
        "prompt-cache"
    ],
    "authors": [
        {
            "name": "Mostafa Elbayyar",
            "email": "mostafa.m.elbiar2@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "mostafax/dynamic-hybrid-reporting-engine": "dev-main",
        "mostafax/dual-layer-reporting-engine": "dev-main"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "suggest": {
        "mongodb/laravel-mongodb": "Required for the MongoDB-backed mapping and prompt-cache stores (^4.0|^5.0)"
    },
    "autoload": {
        "psr-4": {
            "Mostafax\\AiReportingEngine\\": "src/",
            "Mostafax\\AiReportingEngine\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mostafax\\AiReportingEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mostafax\\AiReportingEngine\\AiReportingEngineServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
